# Configuración de Entorno - Superhéroes App
# Copiar este archivo a .env y completar con tus valores

# ==========================================
# CREDENCIALES DE ADMIN (REQUERIDO)
# ==========================================
# CAMBIAR ESTOS VALORES EN PRODUCCIÓN
ADMIN_USERNAME=tu_usuario_admin_seguro
ADMIN_PASSWORD=tu_contraseña_segura_123!

# ==========================================
# CONFIGURACIÓN FIREBASE (OPCIONAL)
# ==========================================
# Descomentar y configurar para usar Firebase en lugar de LocalStorage
USE_FIREBASE=false
FIREBASE_API_KEY=tu_api_key
FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
FIREBASE_PROJECT_ID=tu_proyecto
FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# ==========================================
# SEGURIDAD
# ==========================================
# Requerir HTTPS (deshabilitar solo para desarrollo local)
REQUIRE_HTTPS=true

# Tiempo de expiración de sesión en milisegundos (1 hora = 3600000)
SESSION_TIMEOUT=3600000

# Habilitar encriptación de datos sensibles en localStorage
ENABLE_ENCRYPTION=false
